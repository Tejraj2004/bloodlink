<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Flash Messages -->
  <% if (success && success.length > 0) { %>
    <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-2xl flex items-center gap-3 shadow-sm">
      <span class="text-2xl">✅</span><span class="font-medium"><%= success %></span>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-800 rounded-2xl flex items-center gap-3 shadow-sm">
      <span class="text-2xl">⚠️</span><span class="font-medium"><%= error %></span>
    </div>
  <% } %>

  <!-- Welcome Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-black text-gray-900">Welcome back, <span class="gradient-text"><%= user.name.split(' ')[0] %></span> 👋</h1>
      <p class="text-gray-500 mt-1">Manage your donor profile and blood requests from here.</p>
    </div>
    <div class="flex gap-3">
      <a href="/dashboard/donor/setup" class="btn-primary px-5 py-2.5 text-white rounded-xl font-semibold text-sm shadow flex items-center gap-2">
        🩸 <%= donor ? 'Update Donor Profile' : 'Register as Donor' %>
      </a>
      <a href="/requests/new" class="px-5 py-2.5 border-2 border-blood-600 text-blood-700 rounded-xl font-semibold text-sm hover:bg-red-50 transition flex items-center gap-2">
        🚨 Post Request
      </a>
    </div>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover">
      <div class="text-3xl mb-2">🩸</div>
      <div class="text-2xl font-black gradient-text"><%= donor ? donor.bloodGroup : '—' %></div>
      <div class="text-sm text-gray-500">Your Blood Type</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover">
      <div class="text-3xl mb-2">💚</div>
      <div class="text-2xl font-black text-green-600"><%= donor ? donor.livesSaved : 0 %></div>
      <div class="text-sm text-gray-500">Lives Saved</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover">
      <div class="text-3xl mb-2">📋</div>
      <div class="text-2xl font-black text-blue-600"><%= myRequests.length %></div>
      <div class="text-sm text-gray-500">My Requests</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover">
      <div class="text-3xl mb-2">📍</div>
      <div class="text-2xl font-black text-orange-500"><%= donor ? (donor.isAvailable ? 'Active' : 'Off') : 'N/A' %></div>
      <div class="text-sm text-gray-500">Donor Status</div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="mb-6 border-b border-gray-200">
    <div class="flex gap-1 overflow-x-auto" id="tabBar">
      <button onclick="showTab('overview')" class="tab-btn active px-5 py-3 font-semibold text-sm rounded-t-xl whitespace-nowrap transition" data-tab="overview">📊 Overview</button>
      <button onclick="showTab('donor')" class="tab-btn px-5 py-3 font-semibold text-sm rounded-t-xl whitespace-nowrap transition" data-tab="donor">🩸 As Donor</button>
      <button onclick="showTab('seeker')" class="tab-btn px-5 py-3 font-semibold text-sm rounded-t-xl whitespace-nowrap transition" data-tab="seeker">🏥 As Seeker</button>
    </div>
  </div>

  <!-- OVERVIEW TAB -->
  <div id="tab-overview" class="tab-content">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Donor Profile Summary -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-800 text-lg mb-4 flex items-center gap-2">🩸 Donor Profile</h3>
        <% if (donor) { %>
          <div class="space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-gray-50">
              <span class="text-gray-500 text-sm">Blood Group</span>
              <span class="font-bold text-blood-700 bg-red-50 px-3 py-1 rounded-full text-sm"><%= donor.bloodGroup %></span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-50">
              <span class="text-gray-500 text-sm">Eligibility</span>
              <span class="font-semibold text-sm <%= donor.isEligible ? 'text-green-600' : 'text-red-600' %>">
                <%= donor.isEligible ? '✅ Eligible' : '❌ Not Eligible' %>
              </span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-50">
              <span class="text-gray-500 text-sm">Availability</span>
              <span class="font-semibold text-sm <%= donor.isAvailable ? 'text-green-600' : 'text-gray-500' %>">
                <%= donor.isAvailable ? '🟢 Available' : '🔴 Unavailable' %>
              </span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-50">
              <span class="text-gray-500 text-sm">Last Donated</span>
              <span class="font-semibold text-sm text-gray-700"><%= donor.lastDonatedAt ? new Date(donor.lastDonatedAt).toLocaleDateString('en-IN') : 'Never' %></span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-gray-500 text-sm">Lives Saved</span>
              <span class="font-black text-lg text-green-600"><%= donor.livesSaved %> 💚</span>
            </div>
          </div>
          <% if (donor.donationHistory && donor.donationHistory.length > 0) { %>
            <div class="mt-4 pt-4 border-t border-gray-100">
              <h4 class="text-sm font-semibold text-gray-600 mb-2">Recent Donations</h4>
              <% donor.donationHistory.slice(-3).reverse().forEach(d => { %>
                <div class="flex justify-between text-sm py-1">
                  <span class="text-gray-600"><%= d.patientName %></span>
                  <span class="text-gray-400"><%= new Date(d.date).toLocaleDateString('en-IN') %></span>
                </div>
              <% }) %>
            </div>
          <% } %>
        <% } else { %>
          <div class="text-center py-8">
            <div class="text-5xl mb-3">🩸</div>
            <p class="text-gray-500 mb-4">You haven't set up your donor profile yet.</p>
            <a href="/dashboard/donor/setup" class="btn-primary px-6 py-2.5 text-white rounded-xl font-semibold text-sm inline-block">Register as Donor</a>
          </div>
        <% } %>
      </div>

      <!-- Recent Requests -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-800 text-lg mb-4 flex items-center gap-2">📋 My Recent Requests</h3>
        <% if (myRequests.length > 0) { %>
          <div class="space-y-3">
            <% myRequests.slice(0,4).forEach(r => { %>
              <div class="urgency-<%= r.urgency %> p-3 rounded-xl">
                <div class="flex justify-between items-start">
                  <div>
                    <div class="font-semibold text-gray-800 text-sm"><%= r.patientName %></div>
                    <div class="text-xs text-gray-500 mt-0.5"><%= r.bloodGroupNeeded %> • <%= r.hospitalName %></div>
                  </div>
                  <div class="text-right">
                    <span class="text-xs font-bold uppercase px-2 py-1 rounded-full
                      <%= r.status === 'fulfilled' ? 'bg-green-100 text-green-700' :
                         r.status === 'matched' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600' %>">
                      <%= r.status %>
                    </span>
                  </div>
                </div>
                <% if (r.status === 'matched') { %>
                  <form action="/dashboard/request/<%= r._id %>/recovered" method="POST" class="mt-2">
                    <button type="submit" onclick="return confirm('Mark <%= r.patientName %> as recovered?')" class="text-xs bg-green-500 text-white px-3 py-1 rounded-lg hover:bg-green-600 transition font-medium">
                      ✅ Mark Recovered
                    </button>
                  </form>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-8">
            <div class="text-5xl mb-3">📋</div>
            <p class="text-gray-500 mb-4">No blood requests posted yet.</p>
            <a href="/requests/new" class="btn-primary px-6 py-2.5 text-white rounded-xl font-semibold text-sm inline-block">Post Request</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- DONOR TAB -->
  <div id="tab-donor" class="tab-content hidden">
    <% if (!donor) { %>
      <div class="text-center py-16">
        <div class="text-7xl mb-4">🩸</div>
        <h3 class="text-2xl font-bold text-gray-700 mb-2">Register as Donor First</h3>
        <p class="text-gray-500 mb-6">Complete your donor profile to see matching patient requests near you.</p>
        <a href="/dashboard/donor/setup" class="btn-primary px-8 py-3 text-white rounded-xl font-bold text-lg inline-block">Set Up Donor Profile</a>
      </div>
    <% } else if (!donor.isEligible) { %>
      <div class="text-center py-16 bg-white rounded-2xl border border-yellow-200">
        <div class="text-7xl mb-4">⚠️</div>
        <h3 class="text-2xl font-bold text-yellow-700 mb-2">Currently Not Eligible</h3>
        <p class="text-gray-500 mb-4">You may not be eligible to donate due to recent donation, medical conditions, or low weight.</p>
        <a href="/dashboard/donor/setup" class="px-6 py-2.5 border border-yellow-500 text-yellow-700 rounded-xl font-semibold inline-block hover:bg-yellow-50">Update Profile</a>
      </div>
    <% } else { %>
      <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-2xl flex items-center gap-3">
        <span class="text-2xl">✅</span>
        <div>
          <div class="font-bold text-green-800">You are eligible to donate!</div>
          <div class="text-sm text-green-600">Your blood type <strong><%= donor.bloodGroup %></strong> • Showing compatible requests within 50km</div>
        </div>
      </div>

      <% if (matchedRequests.length === 0) { %>
        <div class="text-center py-16 bg-white rounded-2xl border">
          <div class="text-7xl mb-4">🔍</div>
          <h3 class="text-xl font-bold text-gray-600">No requests near you right now</h3>
          <p class="text-gray-400 mt-2">Check back later — new requests are posted daily.</p>
        </div>
      <% } else { %>
        <!-- Compatible -->
        <% const compatible = matchedRequests.filter(m => m.compatible); %>
        <% const incompatible = matchedRequests.filter(m => !m.compatible); %>

        <% if (compatible.length > 0) { %>
          <h3 class="text-lg font-bold text-green-700 mb-3 flex items-center gap-2">✅ Compatible Patients (<%= compatible.length %>)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            <% compatible.forEach(m => { %>
              <div class="bg-white border border-green-200 rounded-2xl p-5 shadow-sm card-hover">
                <div class="flex justify-between items-start mb-3">
                  <div>
                    <div class="font-bold text-gray-800"><%= m.request.patientName %></div>
                    <div class="text-sm text-gray-500">Age <%= m.request.patientAge %></div>
                  </div>
                  <span class="text-sm font-black px-3 py-1 rounded-full bg-red-100 text-blood-700"><%= m.request.bloodGroupNeeded %></span>
                </div>
                <div class="space-y-1.5 text-sm mb-4">
                  <div class="flex items-center gap-2 text-gray-600">🏥 <%= m.request.hospitalName %></div>
                  <div class="flex items-center gap-2 text-gray-600">📍 <%= m.request.hospitalAddress %></div>
                  <% if (m.distance !== null) { %><div class="flex items-center gap-2 text-blue-600">📏 <%= m.distance.toFixed(1) %> km away</div><% } %>
                  <div class="flex items-center gap-2 text-gray-600">💧 <%= m.request.unitsNeeded %> unit(s) needed</div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-bold uppercase px-3 py-1 rounded-full
                    <%= m.request.urgency === 'critical' ? 'bg-red-600 text-white' :
                       m.request.urgency === 'high' ? 'bg-orange-500 text-white' :
                       m.request.urgency === 'medium' ? 'bg-yellow-500 text-white' : 'bg-blue-500 text-white' %>">
                    <%= m.request.urgency === 'critical' ? '🔴' : m.request.urgency === 'high' ? '🟠' : m.request.urgency === 'medium' ? '🟡' : '🔵' %> <%= m.request.urgency %>
                  </span>
                  <form action="/dashboard/donor/accept/<%= m.request._id %>" method="POST">
                    <button type="submit" onclick="return confirm('Accept donation request for <%= m.request.patientName %>? An SMS will be sent to the contact person.')"
                      class="btn-primary px-4 py-2 text-white rounded-xl text-sm font-bold">
                      💪 Accept & Help
                    </button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <% if (incompatible.length > 0) { %>
          <h3 class="text-lg font-bold text-red-600 mb-3 flex items-center gap-2">❌ Incompatible Patients (<%= incompatible.length %>)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% incompatible.forEach(m => { %>
              <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5 opacity-75">
                <div class="flex justify-between items-start mb-2">
                  <div class="font-semibold text-gray-600"><%= m.request.patientName %></div>
                  <span class="text-sm font-black px-3 py-1 rounded-full bg-gray-200 text-gray-600"><%= m.request.bloodGroupNeeded %></span>
                </div>
                <div class="text-xs text-gray-500 mb-2">🏥 <%= m.request.hospitalName %></div>
                <div class="text-xs bg-red-50 border border-red-100 text-red-700 p-2 rounded-lg">
                  ⚠️ <%= m.reason %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      <% } %>
    <% } %>
  </div>

  <!-- SEEKER TAB -->
  <div id="tab-seeker" class="tab-content hidden">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-bold text-gray-800">My Blood Requests</h3>
      <a href="/requests/new" class="btn-primary px-4 py-2 text-white rounded-xl text-sm font-bold">+ New Request</a>
    </div>
    <% if (myRequests.length === 0) { %>
      <div class="text-center py-16 bg-white rounded-2xl border">
        <div class="text-7xl mb-4">🏥</div>
        <h3 class="text-xl font-bold text-gray-600">No requests yet</h3>
        <p class="text-gray-400 mt-2 mb-6">Post a blood request for a patient and we'll find matching donors near you.</p>
        <a href="/requests/new" class="btn-primary px-8 py-3 text-white rounded-xl font-bold inline-block">🚨 Post Blood Request</a>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% myRequests.forEach(r => { %>
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 card-hover urgency-<%= r.urgency %>">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xl font-black text-blood-700"><%= r.bloodGroupNeeded %></span>
                  <span class="font-bold text-gray-800"><%= r.patientName %></span>
                  <span class="text-xs font-bold uppercase px-2 py-0.5 rounded-full
                    <%= r.status === 'fulfilled' ? 'bg-green-100 text-green-700' :
                       r.status === 'matched' ? 'bg-blue-100 text-blue-700' :
                       r.status === 'expired' ? 'bg-gray-100 text-gray-500' : 'bg-yellow-100 text-yellow-700' %>">
                    <%= r.status %>
                  </span>
                </div>
                <div class="text-sm text-gray-600 space-y-1">
                  <div>🏥 <%= r.hospitalName %> • <%= r.hospitalAddress %></div>
                  <div>📞 Contact: <%= r.contactPhone %> <%= r.contactPerson ? '(' + r.contactPerson + ')' : '' %></div>
                  <div>📅 Posted: <%= new Date(r.createdAt).toLocaleDateString('en-IN') %></div>
                  <div>💧 <%= r.unitsNeeded %> unit(s) needed</div>
                </div>
                <% if (r.matches && r.matches.length > 0) { %>
                  <div class="mt-2 text-sm text-blue-600 font-medium">
                    🤝 <%= r.matches.filter(m => m.status === 'accepted').length %> donor(s) accepted
                  </div>
                <% } %>
              </div>
              <div class="flex flex-col gap-2 items-end">
                <span class="text-xs font-bold uppercase px-3 py-1 rounded-full
                  <%= r.urgency === 'critical' ? 'bg-red-600 text-white' :
                     r.urgency === 'high' ? 'bg-orange-500 text-white' :
                     r.urgency === 'medium' ? 'bg-yellow-500 text-white' : 'bg-blue-500 text-white' %>">
                  <%= r.urgency === 'critical' ? '🔴' : r.urgency === 'high' ? '🟠' : r.urgency === 'medium' ? '🟡' : '🔵' %> <%= r.urgency %>
                </span>
                <% if (r.status === 'matched') { %>
                  <form action="/dashboard/request/<%= r._id %>/recovered" method="POST">
                    <button type="submit" onclick="return confirm('Mark patient as recovered? This will update the donor\'s life saved count.')"
                      class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-xl text-sm font-bold transition">
                      ✅ Mark Recovered
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<script>
function showTab(name) {
  document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.tab-btn').forEach(el => {
    el.classList.remove('active','bg-blood-600','text-white');
    el.classList.add('text-gray-500','hover:text-blood-600');
  });
  document.getElementById('tab-' + name).classList.remove('hidden');
  const btn = document.querySelector(`[data-tab="${name}"]`);
  btn.classList.add('bg-blood-600','text-white');
  btn.classList.remove('text-gray-500');
}
document.addEventListener('DOMContentLoaded', () => showTab('overview'));
</script>

<%- include('../partials/footer') %>
