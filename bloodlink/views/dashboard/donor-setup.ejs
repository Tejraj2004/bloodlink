<%- include('../partials/header') %>

<div class="max-w-3xl mx-auto px-4 py-10">
  <div class="mb-8">
    <a href="/dashboard" class="text-blood-600 hover:text-blood-800 text-sm font-medium flex items-center gap-1">← Back to Dashboard</a>
    <h1 class="text-3xl font-black text-gray-900 mt-3">🩸 <%= donor ? 'Update' : 'Set Up' %> Donor Profile</h1>
    <p class="text-gray-500 mt-1">Fill in your details to get matched with patients who need blood near you.</p>
  </div>

  <% if (error && error.length > 0) { %>
    <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-2xl">⚠️ <%= error %></div>
  <% } %>
  <% if (success && success.length > 0) { %>
    <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-2xl">✅ <%= success %></div>
  <% } %>

  <form action="/dashboard/donor/setup" method="POST" class="space-y-6">
    <!-- Step 1: Personal -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2"><span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">1</span> Personal Details</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Age *</label>
          <input type="number" name="age" min="18" max="65" required value="<%= donor ? donor.age : '' %>" placeholder="25" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Gender *</label>
          <select name="gender" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition">
            <option value="">Select</option>
            <% ['Male','Female','Other'].forEach(g => { %>
              <option value="<%= g %>" <%= donor && donor.gender===g ? 'selected' : '' %>><%= g %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Weight (kg) *</label>
          <input type="number" name="weight" min="30" required value="<%= donor ? donor.weight : '' %>" placeholder="65" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
          <p class="text-xs text-gray-400 mt-1">Minimum 45 kg required</p>
        </div>
      </div>
    </div>

    <!-- Step 2: Medical -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2"><span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">2</span> 🧬 Medical Details</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Blood Group *</label>
          <select name="bloodGroup" required id="bloodGroupSelect" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition">
            <option value="">Select Blood Group</option>
            <% ['A+','A-','B+','B-','O+','O-','AB+','AB-'].forEach(bg => { %>
              <option value="<%= bg %>" <%= donor && donor.bloodGroup===bg ? 'selected' : '' %>><%= bg %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Last Donation Date</label>
          <input type="date" name="lastDonatedAt" value="<%= donor && donor.lastDonatedAt ? new Date(donor.lastDonatedAt).toISOString().split('T')[0] : '' %>" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
          <p class="text-xs text-gray-400 mt-1">Must be 3+ months ago to be eligible</p>
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-semibold text-gray-700 mb-2">Medical Conditions (if any)</label>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
          <% ['Diabetes','HIV','Hepatitis B','Hepatitis C','Heart Disease','Hypertension'].forEach(cond => { %>
            <label class="flex items-center gap-2 p-2 border border-gray-200 rounded-lg cursor-pointer hover:bg-red-50 transition">
              <input type="checkbox" name="medicalConditions" value="<%= cond %>" <%= donor && donor.medicalConditions.includes(cond) ? 'checked' : '' %> class="accent-blood-600"/>
              <span class="text-sm text-gray-700"><%= cond %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Currently on medication?</label>
        <div class="flex gap-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="onMedication" value="yes" <%= donor && donor.onMedication ? 'checked' : '' %> class="accent-blood-600"/> <span class="text-sm">Yes</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="onMedication" value="no" <%= !donor || !donor.onMedication ? 'checked' : '' %> class="accent-blood-600"/> <span class="text-sm">No</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Step 3: Location -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2"><span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">3</span> 📍 Location</h2>
      <button type="button" onclick="detectLocation()" class="mb-4 flex items-center gap-2 px-5 py-2.5 bg-blue-50 border border-blue-200 text-blue-700 rounded-xl hover:bg-blue-100 transition font-medium text-sm">
        📍 Detect My Location via GPS
      </button>
      <div id="locationStatus" class="text-sm text-gray-500 mb-3 hidden"></div>
      <input type="hidden" name="lat" id="lat" value="<%= donor ? donor.lat : '' %>"/>
      <input type="hidden" name="lng" id="lng" value="<%= donor ? donor.lng : '' %>"/>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">City *</label>
          <input type="text" name="city" required id="cityInput" value="<%= donor ? donor.city : user.city %>" placeholder="Bhubaneswar" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Pincode</label>
          <input type="text" name="pincode" value="<%= donor ? donor.pincode : '' %>" placeholder="751001" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
      </div>
    </div>

    <!-- Step 4: Availability & Contact -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2"><span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">4</span> 📞 Availability & Contact</h2>
      <div class="mb-4 flex items-center gap-3">
        <input type="checkbox" name="isAvailable" id="isAvailable" <%= !donor || donor.isAvailable ? 'checked' : '' %> class="w-5 h-5 accent-blood-600 cursor-pointer"/>
        <label for="isAvailable" class="text-sm font-semibold text-gray-700 cursor-pointer">I am available to donate right now</label>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Phone Number *</label>
          <input type="tel" name="phone" required value="<%= donor ? donor.phone : user.phone %>" placeholder="+91 98765 43210" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Preferred Contact Method</label>
          <select name="contactMethod" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition">
            <% ['call','sms','whatsapp'].forEach(m => { %>
              <option value="<%= m %>" <%= donor && donor.contactMethod===m ? 'selected' : '' %>><%= m.charAt(0).toUpperCase()+m.slice(1) %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>

    <button type="submit" class="btn-primary w-full py-4 text-white rounded-2xl font-black text-lg shadow-xl">
      🩸 <%= donor ? 'Update Donor Profile' : 'Register as Donor' %>
    </button>
  </form>
</div>

<script>
function detectLocation() {
  const status = document.getElementById('locationStatus');
  status.classList.remove('hidden');
  status.textContent = '📡 Detecting your location...';
  if (!navigator.geolocation) { status.textContent = '❌ Geolocation not supported.'; return; }
  navigator.geolocation.getCurrentPosition(pos => {
    document.getElementById('lat').value = pos.coords.latitude;
    document.getElementById('lng').value = pos.coords.longitude;
    status.textContent = `✅ Location detected: ${pos.coords.latitude.toFixed(4)}, ${pos.coords.longitude.toFixed(4)}`;
    status.classList.add('text-green-600');
    // Reverse geocode city
    fetch(`https://nominatim.openstreetmap.org/reverse?lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&format=json`)
      .then(r => r.json()).then(d => {
        const city = d.address?.city || d.address?.town || d.address?.state_district || '';
        if (city) document.getElementById('cityInput').value = city;
      }).catch(() => {});
  }, err => { status.textContent = '❌ Could not detect location. Please enter manually.'; });
}
</script>

<%- include('../partials/footer') %>
