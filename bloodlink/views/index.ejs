<%- include('partials/header') %>

<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-red-50 via-white to-red-50 py-20">
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-10 left-10 text-9xl">🩸</div>
    <div class="absolute top-40 right-20 text-7xl">🩸</div>
    <div class="absolute bottom-20 left-1/3 text-8xl">🩸</div>
  </div>
  <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
    <div class="inline-flex items-center gap-2 bg-red-100 text-red-800 px-4 py-2 rounded-full text-sm font-medium mb-6">
      <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
      <% if (criticalRequests > 0) { %>
        <%= criticalRequests %> Critical requests need attention right now
      <% } else { %>
        India's trusted blood donation network
      <% } %>
    </div>
    <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-6 leading-tight">
      Every Drop<br/><span class="gradient-text">Counts</span>
    </h1>
    <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">Connect blood donors with patients in need. One donation can save up to 3 lives. Be someone's hero today.</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4 mb-12">
      <a href="/auth/register" class="btn-primary px-8 py-4 text-white rounded-xl font-bold text-lg shadow-xl inline-flex items-center justify-center gap-2">
        🩸 Become a Donor
      </a>
      <a href="/requests/new" class="px-8 py-4 border-2 border-blood-600 text-blood-700 rounded-xl font-bold text-lg hover:bg-blood-50 transition inline-flex items-center justify-center gap-2">
        🚨 Post Blood Request
      </a>
    </div>
    <!-- Stats -->
    <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto">
      <div class="text-center">
        <div class="text-4xl font-black gradient-text" id="donorCount">0</div>
        <div class="text-sm text-gray-500 mt-1">Donors Registered</div>
      </div>
      <div class="text-center border-x border-red-200">
        <div class="text-4xl font-black gradient-text" id="livesCount">0</div>
        <div class="text-sm text-gray-500 mt-1">Lives Saved</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-black text-orange-600">24/7</div>
        <div class="text-sm text-gray-500 mt-1">Always Available</div>
      </div>
    </div>
  </div>
</section>

<!-- Blood Groups Visual -->
<section class="py-16 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center text-gray-800 mb-3">All Blood Groups Welcome</h2>
    <p class="text-center text-gray-500 mb-10">We connect every blood type to those in need</p>
    <div class="grid grid-cols-4 md:grid-cols-8 gap-3">
      <% ['A+','A-','B+','B-','O+','O-','AB+','AB-'].forEach(bg => { %>
      <div class="card-hover bg-gradient-to-b from-red-50 to-white border border-red-100 rounded-2xl p-4 text-center cursor-pointer">
        <div class="text-2xl font-black gradient-text"><%= bg %></div>
        <div class="text-xs text-gray-400 mt-1">Blood Type</div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center text-gray-800 mb-3">How BloodLink Works</h2>
    <p class="text-center text-gray-500 mb-14">Simple, fast, and life-saving in 3 steps</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="card-hover bg-white rounded-2xl p-8 shadow-md border border-gray-100 text-center relative">
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 w-10 h-10 bg-blood-600 text-white rounded-full flex items-center justify-center font-bold text-lg">1</div>
        <div class="text-5xl mb-4 mt-2">📝</div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">Register & Profile</h3>
        <p class="text-gray-500">Create your account with Google or email. Fill your donor details or post a blood request for a patient.</p>
      </div>
      <div class="card-hover bg-white rounded-2xl p-8 shadow-md border border-gray-100 text-center relative">
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 w-10 h-10 bg-blood-600 text-white rounded-full flex items-center justify-center font-bold text-lg">2</div>
        <div class="text-5xl mb-4 mt-2">🤝</div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">AI Smart Matching</h3>
        <p class="text-gray-500">Our AI matches compatible donors within 50km, ranks by blood compatibility, distance, and urgency.</p>
      </div>
      <div class="card-hover bg-white rounded-2xl p-8 shadow-md border border-gray-100 text-center relative">
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 w-10 h-10 bg-blood-600 text-white rounded-full flex items-center justify-center font-bold text-lg">3</div>
        <div class="text-5xl mb-4 mt-2">💉</div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">Donate & Save Life</h3>
        <p class="text-gray-500">Donor accepts, contact gets SMS with donor details, they meet at the hospital and a life is saved!</p>
      </div>
    </div>
  </div>
</section>

<!-- Why Donate -->
<section class="py-16 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-4xl font-black text-gray-800 mb-6">Why Donate Blood?</h2>
        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 rounded-xl bg-red-50 border border-red-100">
            <span class="text-2xl">🦸</span>
            <div><h4 class="font-bold text-gray-800">Save up to 3 lives</h4><p class="text-sm text-gray-500">One donation separates into red cells, platelets & plasma — each saves a different patient.</p></div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-orange-50 border border-orange-100">
            <span class="text-2xl">💗</span>
            <div><h4 class="font-bold text-gray-800">Health benefits for you</h4><p class="text-sm text-gray-500">Regular donation helps reduce risk of heart disease and burn excess iron.</p></div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-green-50 border border-green-100">
            <span class="text-2xl">🔄</span>
            <div><h4 class="font-bold text-gray-800">Blood replenishes in 56 days</h4><p class="text-sm text-gray-500">Your body fully replaces donated blood within 8 weeks — it's completely safe.</p></div>
          </div>
        </div>
      </div>
      <div class="text-center">
        <div class="relative inline-block">
          <div class="w-64 h-64 bg-gradient-to-br from-red-100 to-red-200 rounded-full flex items-center justify-center mx-auto shadow-2xl">
            <div class="text-9xl blood-drop">🩸</div>
          </div>
          <div class="absolute -top-4 -right-4 bg-white rounded-full p-3 shadow-lg border border-red-100">
            <div class="text-center"><div class="text-xl font-black gradient-text"><%= totalDonors %>+</div><div class="text-xs text-gray-500">Donors</div></div>
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white rounded-full p-3 shadow-lg border border-red-100">
            <div class="text-center"><div class="text-xl font-black text-green-600"><%= livesSaved %>+</div><div class="text-xs text-gray-500">Lives</div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-gradient-to-r from-blood-800 via-blood-700 to-blood-600">
  <div class="max-w-4xl mx-auto px-4 text-center text-white">
    <h2 class="text-4xl font-black mb-4">Ready to Save a Life?</h2>
    <p class="text-red-200 text-lg mb-8">Join thousands of heroes who have already made a difference. It only takes 20 minutes to donate, but lasts a lifetime for the recipient.</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/auth/register" class="bg-white text-blood-700 px-8 py-4 rounded-xl font-bold text-lg hover:bg-red-50 transition shadow-xl inline-flex items-center justify-center gap-2">
        🩸 Join as Donor
      </a>
      <a href="/requests/new" class="border-2 border-white text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white hover:text-blood-700 transition inline-flex items-center justify-center gap-2">
        🚨 Request Blood
      </a>
    </div>
  </div>
</section>

<script>
// Counter animation
function animateCounter(id, target) {
  let count = 0;
  const step = Math.max(1, Math.floor(target / 60));
  const el = document.getElementById(id);
  const timer = setInterval(() => {
    count = Math.min(count + step, target);
    el.textContent = count;
    if (count >= target) clearInterval(timer);
  }, 30);
}
window.addEventListener('load', () => {
  animateCounter('donorCount', <%= totalDonors %>);
  animateCounter('livesCount', <%= livesSaved %>);
});
</script>

<%- include('partials/footer') %>
