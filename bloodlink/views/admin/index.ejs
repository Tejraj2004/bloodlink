<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Admin Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-black text-gray-900">🛡️ Admin Panel</h1>
      <p class="text-gray-500 mt-1">Manage the entire BloodLink platform from here.</p>
    </div>
    <div class="flex items-center gap-2 bg-purple-100 text-purple-700 px-4 py-2 rounded-xl font-semibold text-sm">
      🔐 Admin: <%= user.name %>
    </div>
  </div>

  <% if (success && success.length > 0) { %>
    <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-2xl">✅ <%= success %></div>
  <% } %>

  <!-- Nav Tabs -->
  <div class="flex gap-2 mb-8 flex-wrap">
    <a href="/admin" class="px-5 py-2.5 bg-purple-600 text-white rounded-xl font-semibold text-sm">📊 Dashboard</a>
    <a href="/admin/users" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm hover:bg-gray-50 transition">👥 Users</a>
    <a href="/admin/requests" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm hover:bg-gray-50 transition">📋 Requests</a>
    <a href="/dashboard" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm hover:bg-gray-50 transition">← My Dashboard</a>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover text-center">
      <div class="text-3xl mb-2">👥</div>
      <div class="text-3xl font-black text-blue-600"><%= stats.totalUsers %></div>
      <div class="text-sm text-gray-500 mt-1">Total Users</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover text-center">
      <div class="text-3xl mb-2">🩸</div>
      <div class="text-3xl font-black gradient-text"><%= stats.totalDonors %></div>
      <div class="text-sm text-gray-500 mt-1">Donors</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover text-center">
      <div class="text-3xl mb-2">📋</div>
      <div class="text-3xl font-black text-orange-500"><%= stats.activeRequests %></div>
      <div class="text-sm text-gray-500 mt-1">Active Requests</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover text-center">
      <div class="text-3xl mb-2">✅</div>
      <div class="text-3xl font-black text-green-600"><%= stats.fulfilledRequests %></div>
      <div class="text-sm text-gray-500 mt-1">Fulfilled</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 card-hover text-center">
      <div class="text-3xl mb-2">💚</div>
      <div class="text-3xl font-black text-green-700"><%= stats.livesSaved %></div>
      <div class="text-sm text-gray-500 mt-1">Lives Saved</div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <!-- Blood Group Distribution -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h3 class="font-bold text-gray-800 text-lg mb-5">🩸 Donor Blood Group Distribution</h3>
      <% const allBG = ['A+','A-','B+','B-','O+','O-','AB+','AB-'];
         const bgMap = {};
         bloodGroupStats.forEach(s => bgMap[s._id] = s.count);
         const maxCount = Math.max(...Object.values(bgMap), 1);
      %>
      <div class="space-y-3">
        <% allBG.forEach(bg => { %>
          <% const count = bgMap[bg] || 0; const pct = Math.round((count/maxCount)*100); %>
          <div class="flex items-center gap-3">
            <span class="text-sm font-bold text-blood-700 w-8"><%= bg %></span>
            <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
              <div class="bg-gradient-to-r from-blood-700 to-blood-500 h-5 rounded-full transition-all" style="width:<%= pct %>%"></div>
            </div>
            <span class="text-sm font-semibold text-gray-600 w-6"><%= count %></span>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Recent Requests -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <div class="flex justify-between items-center mb-5">
        <h3 class="font-bold text-gray-800 text-lg">📋 Recent Requests</h3>
        <a href="/admin/requests" class="text-sm text-blood-600 hover:text-blood-800 font-medium">View all →</a>
      </div>
      <div class="space-y-3">
        <% if (recentRequests.length === 0) { %>
          <p class="text-gray-400 text-sm text-center py-4">No requests yet.</p>
        <% } else { %>
          <% recentRequests.slice(0,6).forEach(r => { %>
            <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
              <div class="flex items-center gap-3">
                <span class="font-black text-blood-700 text-sm bg-red-50 px-2 py-1 rounded-lg"><%= r.bloodGroupNeeded %></span>
                <div>
                  <div class="text-sm font-medium text-gray-700"><%= r.patientName %></div>
                  <div class="text-xs text-gray-400"><%= r.postedBy ? r.postedBy.name : 'N/A' %></div>
                </div>
              </div>
              <span class="text-xs font-bold px-2 py-1 rounded-full
                <%= r.status === 'fulfilled' ? 'bg-green-100 text-green-700' : r.status === 'matched' ? 'bg-blue-100 text-blue-700' : r.status === 'expired' ? 'bg-gray-100 text-gray-500' : 'bg-yellow-100 text-yellow-700' %>">
                <%= r.status %>
              </span>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Recent Users -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <div class="flex justify-between items-center mb-5">
      <h3 class="font-bold text-gray-800 text-lg">👥 Recent Users</h3>
      <a href="/admin/users" class="text-sm text-blood-600 hover:text-blood-800 font-medium">Manage all →</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left py-3 text-gray-500 font-semibold">Name</th>
            <th class="text-left py-3 text-gray-500 font-semibold">Email</th>
            <th class="text-left py-3 text-gray-500 font-semibold">Role</th>
            <th class="text-left py-3 text-gray-500 font-semibold">Joined</th>
          </tr>
        </thead>
        <tbody>
          <% recentUsers.forEach(u => { %>
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
              <td class="py-3 font-medium text-gray-800"><%= u.name %></td>
              <td class="py-3 text-gray-500"><%= u.email %></td>
              <td class="py-3">
                <span class="px-2 py-0.5 rounded-full text-xs font-bold <%= u.role === 'admin' ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= u.role %>
                </span>
              </td>
              <td class="py-3 text-gray-400"><%= new Date(u.createdAt).toLocaleDateString('en-IN') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
