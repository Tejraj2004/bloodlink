<%- include('../partials/header') %>

<div class="max-w-3xl mx-auto px-4 py-10">
  <div class="mb-8">
    <a href="/dashboard" class="text-blood-600 hover:text-blood-800 text-sm font-medium flex items-center gap-1">← Back to Dashboard</a>
    <h1 class="text-3xl font-black text-gray-900 mt-3">🚨 Post Blood Request</h1>
    <p class="text-gray-500 mt-1">All details will be used to match the most compatible donors near you.</p>
  </div>

  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-2xl">⚠️ <%= error %></div>
  <% } %>

  <form action="/requests/new" method="POST" class="space-y-6">

    <!-- Hospital Location -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2">
        <span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">1</span>
        📍 Hospital Location
      </h2>
      <button type="button" onclick="detectHospitalLocation()" class="mb-5 flex items-center gap-2 px-5 py-2.5 bg-blue-50 border border-blue-200 text-blue-700 rounded-xl hover:bg-blue-100 transition font-medium text-sm">
        📍 Detect My Location via GPS
      </button>
      <div id="locStatus" class="text-sm mb-4 hidden"></div>
      <input type="hidden" name="lat" id="lat"/>
      <input type="hidden" name="lng" id="lng"/>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1">Hospital Name *</label>
          <input type="text" name="hospitalName" required placeholder="AIIMS Bhubaneswar" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1">Hospital Address *</label>
          <input type="text" name="hospitalAddress" id="hospitalAddress" required placeholder="Sijua, Patia, Bhubaneswar - 751019" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">City</label>
          <input type="text" name="city" id="cityField" placeholder="Bhubaneswar" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Ward / Room No.</label>
          <input type="text" name="wardRoom" placeholder="Ward 4, Room 12" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1">Attending Doctor</label>
          <input type="text" name="attendingDoctor" placeholder="Dr. Suresh Patel" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
      </div>
    </div>

    <!-- Patient Details -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2">
        <span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">2</span>
        🧑‍⚕️ Patient Details
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1">Patient Full Name *</label>
          <input type="text" name="patientName" required placeholder="Ramesh Kumar" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Age *</label>
          <input type="number" name="patientAge" required min="0" max="120" placeholder="45" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Blood Group Needed *</label>
          <select name="bloodGroupNeeded" id="bloodGroupNeeded" required onchange="updateCompatGrid(this.value)" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition">
            <option value="">Select Blood Group</option>
            <% ['A+','A-','B+','B-','O+','O-','AB+','AB-'].forEach(bg => { %>
              <option value="<%= bg %>"><%= bg %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Units Needed</label>
          <input type="number" name="unitsNeeded" min="1" max="10" value="1" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
      </div>
      <!-- Compatibility Grid -->
      <div id="compatGrid" class="hidden mt-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
        <p class="text-sm font-semibold text-gray-700 mb-3" id="compatTitle">Compatible donor blood types:</p>
        <div class="grid grid-cols-4 gap-2" id="compatCells"></div>
      </div>
    </div>

    <!-- Contact Info -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2">
        <span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">3</span>
        📞 Contact Information
      </h2>
      <p class="text-xs text-gray-500 mb-4 bg-yellow-50 border border-yellow-200 p-3 rounded-xl">⚠️ The contact phone below will receive an SMS when a donor accepts. Make sure it's reachable.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Contact Phone *</label>
          <input type="tel" name="contactPhone" required value="<%= user.phone %>" placeholder="+91 98765 43210" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Contact Person Name</label>
          <input type="text" name="contactPerson" value="<%= user.name %>" placeholder="Your name" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition"/>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1">Additional Notes</label>
          <textarea name="notes" rows="3" placeholder="Diagnosis, urgency details, any special instructions..." class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blood-500 transition resize-none"></textarea>
        </div>
      </div>
    </div>

    <!-- Urgency -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-5 flex items-center gap-2">
        <span class="w-7 h-7 bg-blood-600 text-white rounded-full flex items-center justify-center text-sm font-bold">4</span>
        🚨 Urgency Level
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <label class="urgency-card cursor-pointer">
          <input type="radio" name="urgency" value="low" class="hidden peer"/>
          <div class="peer-checked:ring-2 peer-checked:ring-blue-500 peer-checked:bg-blue-50 border-2 border-blue-200 rounded-2xl p-4 text-center hover:bg-blue-50 transition">
            <div class="text-3xl mb-1">🔵</div>
            <div class="font-bold text-blue-700">Low</div>
            <div class="text-xs text-gray-500 mt-1">Scheduled / Elective</div>
          </div>
        </label>
        <label class="urgency-card cursor-pointer">
          <input type="radio" name="urgency" value="medium" checked class="hidden peer"/>
          <div class="peer-checked:ring-2 peer-checked:ring-yellow-500 peer-checked:bg-yellow-50 border-2 border-yellow-200 rounded-2xl p-4 text-center hover:bg-yellow-50 transition">
            <div class="text-3xl mb-1">🟡</div>
            <div class="font-bold text-yellow-700">Medium</div>
            <div class="text-xs text-gray-500 mt-1">Needed soon</div>
          </div>
        </label>
        <label class="urgency-card cursor-pointer">
          <input type="radio" name="urgency" value="high" class="hidden peer"/>
          <div class="peer-checked:ring-2 peer-checked:ring-orange-500 peer-checked:bg-orange-50 border-2 border-orange-200 rounded-2xl p-4 text-center hover:bg-orange-50 transition">
            <div class="text-3xl mb-1">🟠</div>
            <div class="font-bold text-orange-700">High</div>
            <div class="text-xs text-gray-500 mt-1">Needed today</div>
          </div>
        </label>
        <label class="urgency-card cursor-pointer">
          <input type="radio" name="urgency" value="critical" class="hidden peer"/>
          <div class="peer-checked:ring-2 peer-checked:ring-red-600 peer-checked:bg-red-50 border-2 border-red-300 rounded-2xl p-4 text-center hover:bg-red-50 transition">
            <div class="text-3xl mb-1">🔴</div>
            <div class="font-bold text-red-700">Critical</div>
            <div class="text-xs text-gray-500 mt-1">Emergency / ICU</div>
          </div>
        </label>
      </div>
    </div>

    <button type="submit" class="btn-primary w-full py-4 text-white rounded-2xl font-black text-xl shadow-2xl flex items-center justify-center gap-3">
      🚨 Post Blood Request
    </button>
  </form>
</div>

<script>
const compatMap = {
  'A+': ['A+','A-','O+','O-'], 'A-': ['A-','O-'],
  'B+': ['B+','B-','O+','O-'], 'B-': ['B-','O-'],
  'O+': ['O+','O-'], 'O-': ['O-'],
  'AB+': ['A+','A-','B+','B-','O+','O-','AB+','AB-'],
  'AB-': ['A-','B-','O-','AB-']
};
const allGroups = ['A+','A-','B+','B-','O+','O-','AB+','AB-'];

function updateCompatGrid(patientBG) {
  const grid = document.getElementById('compatGrid');
  const cells = document.getElementById('compatCells');
  const title = document.getElementById('compatTitle');
  if (!patientBG) { grid.classList.add('hidden'); return; }
  grid.classList.remove('hidden');
  title.textContent = `Compatible donor blood types for ${patientBG}:`;
  const compatible = compatMap[patientBG] || [];
  cells.innerHTML = allGroups.map(bg => {
    const ok = compatible.includes(bg);
    return `<div class="flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-semibold ${ok ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-red-50 text-red-400 border border-red-100'}">
      <span>${ok ? '✅' : '❌'}</span><span>${bg}</span>
    </div>`;
  }).join('');
}

function detectHospitalLocation() {
  const status = document.getElementById('locStatus');
  status.classList.remove('hidden');
  status.textContent = '📡 Detecting location...';
  navigator.geolocation.getCurrentPosition(pos => {
    document.getElementById('lat').value = pos.coords.latitude;
    document.getElementById('lng').value = pos.coords.longitude;
    status.textContent = '✅ Location captured!';
    status.className = 'text-sm mb-4 text-green-600';
    fetch(`https://nominatim.openstreetmap.org/reverse?lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&format=json`)
      .then(r => r.json()).then(d => {
        const city = d.address?.city || d.address?.town || d.address?.state_district || '';
        const addr = d.display_name || '';
        if (city) document.getElementById('cityField').value = city;
        if (addr) document.getElementById('hospitalAddress').placeholder = addr;
      }).catch(() => {});
  }, () => { status.textContent = '❌ Could not detect. Enter manually.'; status.className = 'text-sm mb-4 text-red-600'; });
}
</script>

<%- include('../partials/footer') %>
